# Copy this file to .env and fill in the values you need.
# Most provider keys can also be configured per company in the Setra UI.

# === LLM Providers ===
OPENAI_API_KEY=sk-...                # Optional: OpenAI models and default cloud fallback
ANTHROPIC_API_KEY=sk-ant-...         # Optional: Anthropic models
OPENROUTER_API_KEY=sk-or-...         # Optional: OpenRouter model routing
GROQ_API_KEY=gsk_...                 # Optional: Groq-hosted models
GEMINI_API_KEY=AIza...               # Optional: Gemini API access
GOOGLE_API_KEY=...                   # Optional: Google AI access used by some routes and desktop flows
TOGETHER_API_KEY=...                 # Optional: Together provider support

# === Provider Endpoints / Advanced Adapters ===
OPENAI_BASE_URL=                     # Optional: custom OpenAI-compatible endpoint
ANTHROPIC_BASE_URL=                  # Optional: custom Anthropic-compatible endpoint
CUSTOM_OPENAI_API_KEY=               # Optional: custom OpenAI-compatible adapter key
CUSTOM_MODEL_ID=                     # Optional: custom OpenAI-compatible model id
AZURE_OPENAI_ENDPOINT=               # Optional: Azure OpenAI endpoint
AZURE_OPENAI_API_KEY=                # Optional: Azure OpenAI API key
AZURE_OPENAI_API_VERSION=2024-10-21  # Optional: Azure OpenAI API version
AWS_ACCESS_KEY_ID=                   # Optional: AWS Bedrock access key id
AWS_REGION=us-east-1                 # Optional: AWS / Bedrock region
BEDROCK_ENDPOINT=                    # Optional: custom Bedrock endpoint override
GOOGLE_APPLICATION_CREDENTIALS=      # Optional: path to GCP service account JSON for Vertex AI
GCP_PROJECT_ID=                      # Optional: Google Cloud project id
GCP_REGION=us-central1               # Optional: Google Cloud region for Vertex AI
OLLAMA_HOST=http://127.0.0.1:11434   # Optional: Ollama host for local models
EXO_HOST=                            # Optional: Exo provider host override
LM_STUDIO_HOST=                      # Optional: LM Studio host override
MLX_LM_HOST=                         # Optional: MLX LM host override

# === Search / SCM Integrations ===
GITHUB_TOKEN=ghp_...                 # Optional: GitHub issue / PR operations
GITLAB_TOKEN=glpat-...               # Optional: GitLab review tooling
TAVILY_API_KEY=tvly-...              # Optional: Tavily web search
BRAVE_SEARCH_API_KEY=...             # Optional: Brave Search API
SERPER_API_KEY=...                   # Optional: Serper API
WEB_SEARCH_PROVIDER=tavily           # Optional desktop web-search provider: tavily|brave|serper

# === Server ===
SETRA_PORT=3141                      # Server port (default: 3141)
SETRA_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3141  # Optional extra CORS origins
SETRA_INSTANCE_TOKEN=                # Optional bearer token required on /api/* requests
INSTANCE_TOKEN=                      # Optional encryption seed for local secrets storage
SETRA_DATA_DIR=                      # Optional data directory (defaults to ~/.setra)
NODE_ENV=development                 # Runtime mode

# === CLI / Desktop / Dev Tools ===
SETRA_API_URL=http://localhost:3141  # API URL used by local tooling and packages
SETRA_API_KEY=                       # Optional API key used by dev tooling
SETRA_SERVER_URL=http://localhost:3141 # Optional desktop bridge server URL
SETRA_COMPANY_SLUG=default           # Optional default company slug for CLI / desktop helpers
SETRA_REGISTRY_PUBLIC_KEY=           # Optional module registry public key override
SETRA_DEV_MODE=false                 # Optional registry dev mode toggle
SETRA_DEBUG=false                    # Optional debug mode toggle
SETRA_DEPLOYMENT_MODE=oss            # Optional deployment mode hint
SETRA_GOVERNANCE_POLICY=             # Optional governance policy override
SETRA_MODE=                          # Optional security tool installation mode

# === Build / Release ===
CSC_NAME=                            # Optional desktop code-signing identity
S3_RELEASE_BUCKET=                   # Optional release bucket for desktop builds
WIN_CSC_LINK=                        # Optional Windows code-signing certificate
WIN_CSC_KEY_PASSWORD=                # Optional Windows code-signing certificate password

# === Scripts ===
SETRA_SLO_PORT=33141                 # Port used by restart-recovery smoke test
SKILLS_TARGET_COUNT=1100             # Optional skills import target size
SKILLS_MAX_REPOS=12                  # Optional skills import repo limit
