{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "package.json", "tsconfig.json"],
			"outputs": ["dist/**", ".next/**", "out/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build", "^typecheck"],
			"inputs": ["src/**", "tsconfig.json"],
			"outputs": []
		},
		"lint": {
			"inputs": ["src/**"],
			"outputs": []
		},
		"clean": {
			"cache": false
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "**/*.test.ts", "**/*.spec.ts"],
			"outputs": ["coverage/**"]
		}
	}
}
