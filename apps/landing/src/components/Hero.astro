---

---

<section class="relative pt-32 pb-20 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-setra-950/50 via-gray-950 to-gray-950"></div>
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-setra-600/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-6xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-gray-700 bg-gray-900/50 text-sm text-gray-300">
      <span class="w-2 h-2 rounded-full bg-accent-green animate-pulse"></span>
      Open Source · MIT License
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
      <span class="text-white">AI Agents That</span>
      <br />
      <span class="bg-gradient-to-r from-setra-400 to-accent-purple bg-clip-text text-transparent">
        Ship Code
      </span>
    </h1>

    <p class="text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto mb-10 leading-relaxed">
      Multi-agent AI platform for software engineering.
      <br class="hidden md:block" />
      Run AI coding agents anywhere. Remember everything. Ship faster.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="#install" class="px-8 py-3 text-lg font-semibold bg-setra-600 hover:bg-setra-500 rounded-xl transition-all hover:shadow-lg hover:shadow-setra-600/25">
        Install Setra
      </a>
      <a href="https://github.com/qwegle/setra" target="_blank" class="px-8 py-3 text-lg font-semibold border border-gray-700 hover:border-gray-500 rounded-xl transition-colors flex items-center gap-2">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Star on GitHub
      </a>
    </div>

    <!-- Terminal Demo -->
    <div class="max-w-3xl mx-auto rounded-2xl border border-gray-800 bg-gray-900/80 overflow-hidden shadow-2xl shadow-black/50">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-800 bg-gray-900">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
        <span class="ml-4 text-xs text-gray-500 font-mono">~  setra</span>
      </div>
      <div class="p-6 font-mono text-sm leading-relaxed text-left">
        <div class="text-gray-500">$ curl -fsSL https://setra.sh/install.sh | bash</div>
        <div class="text-accent-green mt-1">✓ Setra installed successfully!</div>
        <div class="mt-3 text-gray-500">$ setra init</div>
        <div class="text-accent-green mt-1">✓ Setra initialized in ~/my-project</div>
        <div class="mt-3 text-gray-500">$ setra start</div>
        <div class="text-setra-400 mt-1">⚡ Setra Platform Status</div>
        <div class="text-gray-300 mt-1">
          &nbsp;&nbsp;Server&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-accent-green">● online</span><br/>
          &nbsp;&nbsp;Agents&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;5 total, 2 running<br/>
          &nbsp;&nbsp;Models&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Claude, Gemini, Codex, Ollama
        </div>
        <div class="mt-3 text-gray-500">$ setra team</div>
        <div class="text-gray-300 mt-1">
          &nbsp;&nbsp;CEO&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;planner&nbsp;&nbsp;&nbsp;&nbsp;claude-sonnet-4&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-accent-green">● running</span><br/>
          &nbsp;&nbsp;Dev-1&nbsp;&nbsp;&nbsp;&nbsp;coder&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;gemini-2.5-pro&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-accent-green">● running</span><br/>
          &nbsp;&nbsp;QA&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;tester&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;codex-o4-mini&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-setra-400">○ idle</span>
        </div>
      </div>
    </div>
  </div>
</section>
