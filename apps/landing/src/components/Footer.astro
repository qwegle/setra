---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-800 py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2 font-bold text-lg mb-4">
          <span class="text-xl">⚡</span>
          <span>setra</span>
        </div>
        <p class="text-sm text-gray-500">
          AI agent orchestration platform.<br/>
          Run AI coding agents anywhere,<br/>
          remember everything.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold mb-4 text-gray-300">Product</h4>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
          <li><a href="#install" class="hover:text-white transition-colors">Install</a></li>
          <li><a href="https://github.com/qwegle/setra/releases" class="hover:text-white transition-colors">Releases</a></li>
          <li><a href="https://github.com/qwegle/setra/blob/main/CHANGELOG.md" class="hover:text-white transition-colors">Changelog</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold mb-4 text-gray-300">Resources</h4>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="https://github.com/qwegle/setra/wiki" class="hover:text-white transition-colors">Documentation</a></li>
          <li><a href="https://github.com/qwegle/setra/issues" class="hover:text-white transition-colors">Issues</a></li>
          <li><a href="https://github.com/qwegle/setra/discussions" class="hover:text-white transition-colors">Discussions</a></li>
          <li><a href="https://github.com/qwegle/setra/blob/main/CONTRIBUTING.md" class="hover:text-white transition-colors">Contributing</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold mb-4 text-gray-300">Community</h4>
        <ul class="space-y-2 text-sm text-gray-500">
          <li>
            <a href="https://github.com/qwegle/setra" class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-sm text-gray-500">
        © {year} Qwegle. MIT License.
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/qwegle/setra" class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-white transition-colors">
          <img src="https://img.shields.io/github/stars/qwegle/setra?style=flat&color=0ea5e9" alt="GitHub Stars" class="h-5" />
        </a>
        <a href="https://github.com/qwegle/setra/blob/main/LICENSE" class="inline-flex items-center">
          <img src="https://img.shields.io/badge/license-MIT-green.svg" alt="MIT License" class="h-5" />
        </a>
      </div>
    </div>
  </div>
</footer>
