---

<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold mb-4">Built for performance</h2>
      <p class="text-lg text-gray-400">Polyglot architecture — the right language for every job.</p>
    </div>

    <div class="grid md:grid-cols-4 gap-6">
      <div class="p-6 rounded-2xl border border-blue-900/50 bg-blue-950/20 text-center">
        <div class="text-3xl mb-3 font-bold text-blue-400">Go</div>
        <div class="text-sm text-gray-300 font-medium mb-2">CLI · TUI · Agent Runner</div>
        <div class="text-xs text-gray-500">Single binary · 5ms startup<br/>PTY management · Process control</div>
      </div>

      <div class="p-6 rounded-2xl border border-orange-900/50 bg-orange-950/20 text-center">
        <div class="text-3xl mb-3 font-bold text-orange-400">Rust</div>
        <div class="text-sm text-gray-300 font-medium mb-2">Compute Engine</div>
        <div class="text-xs text-gray-500">NAPI addon · Diff processing<br/>Token counting · Text similarity</div>
      </div>

      <div class="p-6 rounded-2xl border border-cyan-900/50 bg-cyan-950/20 text-center">
        <div class="text-3xl mb-3 font-bold text-cyan-400">TypeScript</div>
        <div class="text-sm text-gray-300 font-medium mb-2">Server · Desktop · Web</div>
        <div class="text-xs text-gray-500">Hono API · React UI · Electron<br/>Drizzle ORM · SQLite</div>
      </div>

      <div class="p-6 rounded-2xl border border-purple-900/50 bg-purple-950/20 text-center">
        <div class="text-3xl mb-3 font-bold text-purple-400">Astro</div>
        <div class="text-sm text-gray-300 font-medium mb-2">Landing Page</div>
        <div class="text-xs text-gray-500">Static site · Tailwind CSS<br/>GitHub Pages · Edge-fast</div>
      </div>
    </div>
  </div>
</section>
