<section id="features" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4">Everything you need to ship with AI agents</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">
        A complete platform for orchestrating AI coding agents. From planning to deployment.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {features.map(f => (
        <div class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50 hover:border-gray-700 transition-colors group">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-setra-400 transition-colors">{f.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
