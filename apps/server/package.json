{
	"name": "@setra/server",
	"version": "0.1.0",
	"private": true,
	"description": "setra.sh control-plane server — Hono REST + SSE",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "NODE_OPTIONS=\"--require ./server-preload.cjs\" node node_modules/tsx/dist/cli.mjs watch src/index.ts",
		"build": "tsup src/index.ts --format esm --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@hono/zod-validator": "^0.4.1",
		"@setra/agent-runner": "workspace:*",
		"@setra/application": "workspace:*",
		"@setra/company": "workspace:*",
		"@setra/contracts": "workspace:*",
		"@setra/core": "workspace:*",
		"@setra/db": "workspace:*",
		"@setra/domain": "workspace:*",
		"@setra/git": "workspace:*",
		"@setra/infrastructure": "workspace:*",
		"@setra/mcp": "workspace:*",
		"@setra/memory": "workspace:*",
		"@setra/monitor": "workspace:*",
		"@setra/shared": "workspace:*",
		"@setra/types": "workspace:*",
		"better-sqlite3": "^11.7.0",
		"bonjour-service": "^1.2.1",
		"drizzle-orm": "^0.38.3",
		"hono": "^4.6.14",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
