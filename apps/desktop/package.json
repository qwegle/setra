{
	"name": "@setra/desktop",
	"version": "0.1.0",
	"private": true,
	"description": "setra.sh desktop app — Electron",
	"license": "Apache-2.0",
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "pnpm --filter @setra/board build && electron-vite build && rm -rf node_modules/@setra && node scripts/prune-broken-workspace-links.cjs && electron-builder --config electron-builder.config.ts",
		"build:dir": "pnpm --filter @setra/board build && electron-vite build && rm -rf node_modules/@setra && node scripts/prune-broken-workspace-links.cjs && electron-builder --config electron-builder.config.ts --dir",
		"typecheck": "tsc --noEmit",
		"preview": "electron-vite preview",
		"clean": "rm -rf out dist",
		"electron:rebuild": "node scripts/electron-rebuild.js"
	},
	"dependencies": {
		"@setra/agent-runner": "workspace:*",
		"@setra/commands": "workspace:*",
		"@setra/core": "workspace:*",
		"@setra/db": "workspace:*",
		"@setra/mcp": "workspace:*",
		"@setra/memory": "workspace:*",
		"@setra/monitor": "workspace:*",
		"@setra/security": "workspace:*",
		"@setra/shared": "workspace:*",
		"@setra/skills": "workspace:*",
		"@setra/types": "workspace:*",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/addon-ligatures": "^0.10.0",
		"@xterm/addon-search": "^0.15.0",
		"@xterm/addon-web-links": "^0.11.0",
		"@xterm/xterm": "^5.5.0",
		"better-sqlite3": "^11.7.0",
		"drizzle-orm": "^0.38.3",
		"electron-log": "^5.2.4",
		"electron-updater": "^6.3.9",
		"lucide-react": "^1.14.0",
		"node-pty": "^1.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router-dom": "^7.1.1",
		"shell-env": "^4.0.1",
		"zod": "^3.24.1",
		"zustand": "^5.0.3"
	},
	"devDependencies": {
		"@electron/rebuild": "^4.0.4",
		"@setra/typescript-config": "workspace:*",
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.5",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"@vitejs/plugin-react": "^4.3.4",
		"electron": "^33.3.1",
		"electron-builder": "^25.1.8",
		"electron-vite": "^3.0.0",
		"node-abi": "^4.31.0",
		"typescript": "^5.7.3",
		"vite": "^6.0.7"
	},
	"productName": "setra"
}
