{
	"name": "@setra/contracts",
	"version": "0.1.0",
	"private": true,
	"description": "Shared Setra API contracts",
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"require": "./dist/index.cjs"
		},
		"./issues": {
			"import": "./dist/issues.js",
			"types": "./dist/issues.d.ts",
			"require": "./dist/issues.cjs"
		},
		"./projects": {
			"import": "./dist/projects.js",
			"types": "./dist/projects.d.ts",
			"require": "./dist/projects.cjs"
		},
		"./agents": {
			"import": "./dist/agents.js",
			"types": "./dist/agents.d.ts",
			"require": "./dist/agents.cjs"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup src/index.ts src/issues.ts src/projects.ts src/agents.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@setra/domain": "workspace:*",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.0",
		"typescript": "^5.7.3"
	}
}
