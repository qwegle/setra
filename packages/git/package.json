{
	"name": "@setra/git",
	"version": "0.1.0",
	"private": true,
	"description": "Git plumbing for setra projects (init, branch, commit, push)",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./github": "./dist/github.js"
	},
	"scripts": {
		"build": "tsup src/index.ts src/github.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"typescript": "^5.7.3"
	}
}
