{
	"name": "@setra/company",
	"version": "0.1.0",
	"description": "setra.sh Company Formation — multi-agent collaboration system",
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./types": "./dist/types.js",
		"./schema": "./dist/schema.js",
		"./broker": "./dist/broker.js",
		"./launcher": "./dist/launcher.js",
		"./mcp-tools": "./dist/mcp-tools.js",
		"./templates": "./dist/templates.js",
		"./ui-spec": "./dist/ui-spec.js"
	},
	"scripts": {
		"build": "tsup src/index.ts src/broker.ts src/launcher.ts src/schema.ts src/mcp-tools.ts src/templates.ts src/ui-spec.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "^0.38.3",
		"nanoid": "^5.0.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"tsup": "^8.0.0",
		"typescript": "^5.4.0"
	},
	"peerDependencies": {
		"better-sqlite3": ">=9.0.0"
	}
}
