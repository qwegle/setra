{
	"name": "@setra/core",
	"version": "0.1.0",
	"private": true,
	"description": "setra.sh core engine \u2014 EventBus, ModuleRegistry, SetraCore bootstrap",
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"require": "./dist/index.cjs"
		},
		"./user-profile.js": {
			"import": "./dist/user-profile.js",
			"types": "./dist/user-profile.d.ts",
			"require": "./dist/user-profile.cjs"
		},
		"./integrations.js": {
			"import": "./dist/integrations.js",
			"types": "./dist/integrations.d.ts",
			"require": "./dist/integrations.cjs"
		},
		"./wiki.js": {
			"import": "./dist/wiki.js",
			"types": "./dist/wiki.d.ts",
			"require": "./dist/wiki.cjs"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts src/user-profile.ts src/integrations.ts src/wiki.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@setra/db": "workspace:*",
		"@setra/types": "workspace:*",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.0",
		"typescript": "^5.7.3"
	}
}
