{
	"name": "@setra/security",
	"version": "0.1.0",
	"description": "Sentinel \u2014 setra's AI-powered security intelligence engine",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --clean",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"typecheck": "tsc --noEmit",
		"test": "jest"
	},
	"dependencies": {
		"@setra/types": "workspace:*",
		"@setra/db": "workspace:*",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.0",
		"typescript": "^5.7.3"
	}
}
