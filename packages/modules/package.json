{
	"name": "@setra/modules",
	"version": "0.1.0",
	"private": true,
	"description": "setra.sh sandboxed module loader \u2014 Ed25519 verify + vm sandbox",
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./registry": "./dist/registry.js",
		"./manifest": "./dist/manifest.js"
	},
	"scripts": {
		"build": "tsup src/registry.ts src/manifest.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@setra/types": "workspace:*",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.0",
		"typescript": "^5.7.3"
	}
}
