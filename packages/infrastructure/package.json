{
	"name": "@setra/infrastructure",
	"version": "0.1.0",
	"private": true,
	"description": "Setra infrastructure adapters for SQLite and typed event delivery",
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@setra/application": "workspace:*",
		"@setra/db": "workspace:*",
		"@setra/domain": "workspace:*"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/node": "^22.10.5",
		"tsup": "^8.3.0",
		"typescript": "^5.7.3"
	}
}
