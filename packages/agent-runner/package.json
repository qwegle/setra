	"dependencies": {
		"@anthropic-ai/sdk": "^0.52.0",
		"@setra/core": "workspace:*",
		"@setra/db": "workspace:*",
		"openai": "^4.77.0"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"typescript": "^5.7.3",
		"mongodb": "^6.13.0",
		"mssql": "^11.0.1",
		"mysql2": "^3.11.5",
		"pg": "^8.13.3"
	},
	"peerDependencies": {
		"mongodb": ">=5",
		"mssql": ">=10",
		"mysql2": ">=3",
		"pg": ">=8"
	},
	"peerDependenciesMeta": {
		"mongodb": {
			"optional": true
		},
		"mssql": {
			"optional": true
		},
		"mysql2": {
			"optional": true
		},
		"pg": {
			"optional": true
		}
	}
}
