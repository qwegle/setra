{
	"name": "@setra/db",
	"version": "0.1.0",
	"private": true,
	"description": "Drizzle ORM schema and client for setra local SQLite database",
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"require": "./dist/index.cjs",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./schema": {
			"require": "./dist/schema/index.cjs",
			"import": "./dist/schema/index.js",
			"types": "./dist/schema/index.d.ts"
		},
		"./client": {
			"require": "./dist/client.cjs",
			"import": "./dist/client.js",
			"types": "./dist/client.d.ts"
		},
		"./client.js": {
			"require": "./dist/client.cjs",
			"import": "./dist/client.js",
			"types": "./dist/client.d.ts"
		},
		"./kanban.js": {
			"require": "./dist/kanban.cjs",
			"import": "./dist/kanban.js",
			"types": "./dist/kanban.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup src/index.ts src/client.ts src/kanban.ts src/schema/index.ts --format esm,cjs --dts --clean --out-dir dist --shims",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"better-sqlite3": "^11.7.0",
		"drizzle-orm": "^0.38.3"
	},
	"devDependencies": {
		"@setra/typescript-config": "workspace:*",
		"@types/better-sqlite3": "^7.6.12",
		"drizzle-kit": "^0.30.1",
		"typescript": "^5.7.3"
	},
	"tsup": {
		"entry": ["src/index.ts", "src/client.ts", "src/schema/index.ts"],
		"format": ["esm"],
		"dts": true
	}
}
